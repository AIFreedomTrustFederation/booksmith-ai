    "phase1:repair:v2:fhqcm": "bash scripts/phase1-repair-v2-loop.sh fhqcm",
    "json:repair": "node scripts/repair-booksmith-json.mjs",
    "json:validate": "node scripts/validate-booksmith-json.mjs"
