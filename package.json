    "zip:latest": "bash scripts/booksmith-export-latest-zip.sh",
    "zip:latest:fhqcm": "bash scripts/booksmith-export-latest-zip.sh fhqcm",
    "repair:proof": "bash scripts/phase1-repair-loop.sh",
    "repair:proof:fhqcm": "bash scripts/phase1-repair-loop.sh fhqcm",
    "repair:queue": "node scripts/booksmith-proof-repair-engine.mjs",
