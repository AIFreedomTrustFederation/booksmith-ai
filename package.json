    "render:latex:fhqcm": "node scripts/render-latex.mjs fhqcm",
    "proof:report": "node scripts/proof-report.mjs",
    "proof:report:fhqcm": "node scripts/proof-report.mjs fhqcm",
    "validate:latex-integrity": "node scripts/validate-latex-integrity.mjs",
    "validate:latex-integrity:fhqcm": "node scripts/validate-latex-integrity.mjs fhqcm",
    "quality:gate": "node scripts/quality-gate.mjs",
    "quality:gate:fhqcm": "node scripts/quality-gate.mjs fhqcm",
